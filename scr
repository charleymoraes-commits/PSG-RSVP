import { useEffect, useState } from 'react';
import { supabase, isSupabaseConfigured } from './supabase';
import { Trophy, LogOut } from 'lucide-react';

export default function App() {
  const [session, setSession] = useState<any>(null);
  const [loading, setLoading] = useState(true);

  useEffect(() => {
    supabase.auth.getSession().then(({ data: { session } }) => {
      setSession(session);
      setLoading(false);
    });
  }, []);

  if (loading) return <div className="min-h-screen bg-black flex items-center justify-center text-green-400">LOADING PSG...</div>;

  return (
    <div className="min-h-screen bg-black text-white p-8">
      <h1 className="text-4xl font-black italic">PSG PERTH</h1>
      <p className="mt-4 text-gray-400">Match Centre coming soon...</p>
      <button onClick={() => supabase.auth.signOut()} className="mt-8 flex items-center gap-2 text-red-500">
        <LogOut size={20} /> Logout
      </button>
    </div>
  );
}
